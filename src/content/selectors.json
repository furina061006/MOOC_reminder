{
  "version": 1,
  "lastUpdated": "2026-06-17",
  "description": "DOM selectors for icourse163.org homework scraping. 只针对'测验与作业'和'考试'两个板块。Update when platform changes frontend.",

  "coursePage": {
    "courseName": {
      "primary": ".m-courseInfo h1, .course-title, .j-course-title, .m-course-title",
      "fallback": ["title", "[data-title]", "h1"]
    },
    "schoolName": {
      "primary": ".m-courseInfo .school, .course-school, .j-school-name",
      "fallback": ["[class*='school']"]
    },
    "chapterContainer": {
      "primary": ".j-chapterlist, .chapter-list, .m-chapter, .j-chapter",
      "fallback": ["[class*='chapter']", "[class*='Chapter']"]
    },
    "chapterItems": {
      "primary": ".j-chapter-item, .m-chapter-item, .chapter-item, .j-chapteritem",
      "fallback": ["[class*='chapter'] > div", "[class*='chapterItem']"]
    },
    "lessonItems": {
      "primary": ".j-lesson-item, .m-lesson-item, .lesson-item, .j-lessonitem, .j-lesson",
      "fallback": ["[class*='lesson']", "[class*='Lesson']"]
    }
  },

  "homeworkDetection": {
    "quizExamPage": {
      "description": "测验与作业 (/learn/quiz) 和 考试 (/learn/exam) 页面的专用选择器",
      "listContainer": {
        "primary": ".j-quizlist, .m-quizlist, .j-testlist, .m-testlist, .j-test-list, .j-examlist, .m-examlist, .j-exam-list",
        "fallback": ["[class*='quizlist']", "[class*='testlist']", "[class*='test-list']", "[class*='examlist']", "[class*='exam-list']", ".j-list-container", ".m-list-container"]
      },
      "tableRow": {
        "primary": ".j-quizlist table tr, .m-quizlist table tr, .j-testlist table tr, .j-examlist table tr, table.j-table tr, table tbody tr",
        "fallback": ["table tr:has(td)", "tr[class*='row']", "tr[class*='item']", "table.j-table tbody tr td"]
      },
      "listItem": {
        "primary": ".j-quiz-item, .m-quiz-item, .j-test-item, .m-test-item, .j-testitem, .j-exam-item, .m-exam-item",
        "fallback": ["[class*='quizItem']", "[class*='testItem']", "[class*='testitem']", "[class*='examItem']", "[class*='listItem']", "[class*='list-item']"]
      }
    },
    "homeworkRow": {
      "primary": ".j-test-item, .m-test-item, .j-quiz-item, .m-quiz-item, .j-exam-item, .m-exam-item, .j-homework-item, .m-homework-item, [class*='testItem'], [class*='homeworkItem']",
      "fallback": ["[class*='test']", "[class*='homework']", "[class*='exam']", "[class*='quiz']", "a[href*='test']", "a[href*='content']"]
    },
    "homeworkTitle": {
      "primary": ".j-test-title, .j-homework-title, .m-test-title, [class*='test-title'], [class*='hwt-title']",
      "fallback": ["a[href*='homework']", "a[href*='exam']", "a[href*='quiz']", "a[href*='test']", "a[href*='content']", "span"]
    },
    "homeworkTypeIndicator": {
      "homework": ["作业", "课后作业", "单元作业"],
      "quiz": ["测验", "单元测验", "随堂测验"],
      "exam": ["考试", "期末考试", "期中考试"],
      "discussion": ["讨论", "课堂交流", "主题讨论"]
    },
    "statusIndicator": {
      "completed": {
        "classPatterns": ["done", "finished", "completed", "is-pass", "is-done", "m-homeworkItem-done", "status-done", "j-done"],
        "textPatterns": ["已完成", "已提交", "已批阅", "已通过", "已截止", "得分"]
      },
      "submitted": {
        "classPatterns": ["submitted", "is-submit", "status-submit"],
        "textPatterns": ["已提交", "待批阅", "提交成功"]
      },
      "unfinished": {
        "classPatterns": ["undone", "todo", "pending", "unfinished"],
        "textPatterns": ["未完成", "待提交", "未提交", "去完成"]
      }
    },
    "deadline": {
      "primary": "[class*='deadline'], [class*='end-time'], [class*='dtime'], [class*='endTime'], .j-deadline",
      "textRegex": "(\\d{4})[年\\-/](\\d{1,2})[月\\-/](\\d{1,2})日?\\s*(\\d{1,2}):(\\d{2})",
      "fallback": ".j-test-info, .m-test-info, .homework-info, [class*='info']"
    },
    "score": {
      "primary": "[class*='score'], [class*='grade'], .j-score, .m-score",
      "fallback": ["[class*='Score']"]
    }
  },

  "spocOverrides": {
    "note": "SPOC courses may use slightly different class prefixes",
    "coursePage": {
      "chapterContainer": {
        "primary": ".spoc-chapterlist, .j-spocChapterlist, .spoc-chapter",
        "fallback": ["[class*='spoc'] [class*='chapter']"]
      }
    }
  },

  "loginWall": {
    "selectors": [".login-form", ".j-login", ".m-login", "#login-form"],
    "note": "If any of these selectors match, user is on login page, not course content"
  },

  "loadingIndicator": {
    "selectors": [".j-loading", ".m-loading", ".loading-spinner", "[class*='loading']", "[class*='Loading']"],
    "note": "Wait for these to disappear before scraping"
  }
}
